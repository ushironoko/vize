{
  "name": "@vizejs/vite-plugin-musea",
  "version": "0.38.0",
  "description": "Vite plugin for Musea - Component gallery for Vue components",
  "keywords": [
    "component-gallery",
    "musea",
    "storybook",
    "vite",
    "vite-plugin",
    "vue"
  ],
  "license": "MIT",
  "author": "ubugeeei",
  "repository": {
    "type": "git",
    "url": "https://github.com/ubugeeei/vize.git",
    "directory": "npm/vite-plugin-musea"
  },
  "bin": {
    "musea-vrt": "./dist/cli/index.mjs"
  },
  "files": [
    "dist",
    "dist/gallery",
    "bin"
  ],
  "type": "module",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.mts"
    },
    "./vrt": {
      "import": "./dist/vrt.mjs",
      "types": "./dist/vrt.d.mts"
    },
    "./cli": {
      "import": "./dist/cli/index.mjs",
      "types": "./dist/cli/index.d.mts"
    },
    "./a11y": {
      "import": "./dist/a11y/index.mjs",
      "types": "./dist/a11y/index.d.mts"
    },
    "./autogen": {
      "import": "./dist/autogen/index.mjs",
      "types": "./dist/autogen/index.d.mts"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vp pack",
    "build:gallery": "vp build --config gallery-vite.config.ts",
    "dev": "vp pack --watch",
    "check": "vp check src vite.config.ts",
    "check:fix": "vp check --fix src vite.config.ts",
    "fmt": "vp fmt --write src vite.config.ts"
  },
  "dependencies": {
    "@vizejs/native": "workspace:*",
    "pngjs": "^7.0.0"
  },
  "devDependencies": {
    "@mdi/js": "^7.4.47",
    "@tsdown/css": "^0.21.2",
    "@types/node": "^22.14.0",
    "@types/pngjs": "^6.0.5",
    "@vitejs/plugin-vue": "^6.0.4",
    "@vizejs/vite-plugin": "workspace:*",
    "highlight.js": "^11.11.1",
    "marked": "^17.0.1",
    "marked-highlight": "^2.2.3",
    "monaco-editor": "^0.52.0",
    "typescript": "^5.7.0",
    "vite": "catalog:",
    "vite-plus": "catalog:",
    "vue": "^3.5.0",
    "vue-router": "^4.5.0"
  },
  "peerDependencies": {
    "@vizejs/vite-plugin": "workspace:*",
    "axe-core": "^4.7.0",
    "playwright": "^1.40.0",
    "vite": "^8.0.0"
  },
  "peerDependenciesMeta": {
    "playwright": {
      "optional": true
    },
    "axe-core": {
      "optional": true
    }
  }
}
