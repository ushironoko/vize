{
  "name": "@vizejs/vite-plugin",
  "version": "0.38.0",
  "description": "High-performance native Vite plugin for Vue SFC compilation powered by Vize",
  "keywords": [
    "compiler",
    "fast",
    "native",
    "plugin",
    "sfc",
    "vite",
    "vue"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ubugeeei/vize",
    "directory": "npm/vite-plugin-vize"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.mts"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vp pack",
    "dev": "vp pack --watch",
    "check": "vp check src vite.config.ts",
    "check:fix": "vp check --fix src vite.config.ts",
    "fmt": "vp fmt --write src vite.config.ts",
    "test": "node --import tsx src/test.ts"
  },
  "dependencies": {
    "@vizejs/native": "workspace:*",
    "tinyglobby": "^0.2.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.21.0",
    "typescript": "~5.6.0",
    "vite": "catalog:",
    "vite-plus": "catalog:"
  },
  "peerDependencies": {
    "vite": "^8.0.0"
  }
}
