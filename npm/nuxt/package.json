{
  "name": "@vizejs/nuxt",
  "version": "0.38.0",
  "description": "Nuxt module for Vize - compiler, musea gallery, linter, and type checker",
  "keywords": [
    "compiler",
    "gallery",
    "linter",
    "musea",
    "nuxt",
    "nuxt-module",
    "type-checker",
    "vize",
    "vue"
  ],
  "license": "MIT",
  "author": "ubugeeei",
  "repository": {
    "type": "git",
    "url": "https://github.com/ubugeeei/vize.git",
    "directory": "npm/nuxt"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vp pack",
    "dev": "vp pack --watch",
    "check": "vp check src vite.config.ts",
    "check:fix": "vp check --fix src vite.config.ts",
    "fmt": "vp fmt --write src vite.config.ts"
  },
  "dependencies": {
    "@nuxt/kit": "^4.0.0",
    "@vizejs/musea-nuxt": "workspace:*",
    "@vizejs/vite-plugin": "workspace:*",
    "@vizejs/vite-plugin-musea": "workspace:*",
    "vize": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "vite": "catalog:",
    "vite-plus": "catalog:",
    "vue": "^3.5.0",
    "vue-router": "^4.5.0"
  },
  "peerDependencies": {
    "nuxt": "^3.0.0 || ^4.0.0"
  }
}
