{
  "name": "@vizejs/musea-nuxt",
  "version": "0.37.0",
  "description": "Nuxt mock layer for Musea - enables Nuxt component isolation in galleries",
  "keywords": [
    "component-gallery",
    "mock",
    "musea",
    "nuxt",
    "vite-plugin"
  ],
  "license": "MIT",
  "author": "ubugeeei",
  "repository": {
    "type": "git",
    "url": "https://github.com/ubugeeei/vize.git",
    "directory": "npm/musea-nuxt"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vp pack",
    "dev": "vp pack --watch",
    "check": "vp check src vite.config.ts",
    "check:fix": "vp check --fix src vite.config.ts",
    "fmt": "vp fmt --write src vite.config.ts"
  },
  "dependencies": {},
  "devDependencies": {
    "typescript": "^5.7.0",
    "vite": "catalog:",
    "vite-plus": "catalog:",
    "vue": "^3.5.0",
    "vue-router": "^4.5.0"
  },
  "peerDependencies": {
    "vite": "^8.0.0",
    "vue": "^3.5.0",
    "vue-router": "^4.5.0"
  }
}
